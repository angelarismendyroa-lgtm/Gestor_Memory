{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["cli/**/*", "core/**/*", "mcp-server/**/*"],
  "exclude": ["node_modules", "visualizer"]
}
